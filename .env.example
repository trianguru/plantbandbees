# PlantBandBees Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=file:./local.db

# Mailchimp Integration
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_AUDIENCE_ID=your_audience_id_here

# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX

# Facebook Pixel
FB_PIXEL_ID=your_facebook_pixel_id_here

# Google Ads
GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXXX
GOOGLE_ADS_CONVERSION_LABEL=your_conversion_label_here

# Application URL (for redirects and webhooks)
APP_URL=http://localhost:5000

# Optional: Zapier Webhook (for lead tracking)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/xxxxx/
